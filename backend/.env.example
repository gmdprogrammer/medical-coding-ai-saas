# ─── Application ─────────────────────────────────────────────────────────────
APP_ENV=development
APP_NAME="Medical Coding AI"
APP_VERSION=1.0.0
DEBUG=false
ALLOWED_ORIGINS=["http://localhost:3000","https://yourdomain.com"]

# ─── Security ────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-256-bit-secret-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/medical_coding
SYNC_DATABASE_URL=postgresql://postgres:password@localhost:5432/medical_coding

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Groq API ────────────────────────────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=2048
GROQ_TEMPERATURE=0.1

# ─── Vector Store ─────────────────────────────────────────────────────────────
VECTOR_STORE_PATH=./data/vector_stores
FAISS_INDEX_PATH=./data/vector_stores/faiss_index
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ─── RAG ─────────────────────────────────────────────────────────────────────
RAG_TOP_K=10
RAG_SIMILARITY_THRESHOLD=0.7

# ─── PHI Anonymization ────────────────────────────────────────────────────────
SPACY_MODEL=en_core_web_lg
PHI_ANONYMIZATION_ENABLED=true

# ─── Data Paths ───────────────────────────────────────────────────────────────
ICD10_DATA_PATH=./data/icd10
CPT_DATA_PATH=./data/cpt
HCPCS_DATA_PATH=./data/hcpcs
